{
  "name": "Contact",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "linkedin": {
      "type": "string"
    },
    "birthday": {
      "type": "string",
      "format": "date"
    },
    "relationship_notes": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "company_type": {
      "type": "string",
      "enum": [
        "Client",
        "TradeAccount",
        "OtherPartner"
      ],
      "description": "Type of company this contact primarily belongs to"
    },
    "company_id": {
      "type": "string",
      "description": "ID of primary linked company"
    },
    "company_name": {
      "type": "string",
      "description": "Denormalized primary company name"
    },
    "linked_clients": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of clients this contact is associated with (can span multiple)"
    },
    "linked_client_names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Denormalized client names for display"
    }
  },
  "required": [
    "name"
  ]
}